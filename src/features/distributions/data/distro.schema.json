{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aptlantis.net/schemas/distro.schema.json",
  "title": "APTlantis Distro Metadata",
  "type": "object",

  "properties": {
    "id": {
      "type": "string",
      "description": "Unique short identifier (e.g. 'parrot', 'antix', 'mx')."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the distribution."
    },
    "description": {
      "type": "string",
      "description": "Short description (1-2 sentences) for card display."
    },
    "longDescription": {
      "type": "string",
      "description": "Extended description with multiple paragraphs for detail pages."
    },

    "homepage": { "type": "string", "format": "uri" },
    "documentation_url": { "type": "string", "format": "uri" },
    "bug_tracker_url": { "type": "string", "format": "uri" },
    "wiki_url": { "type": "string", "format": "uri" },

    "buttonColor": {
      "type": "string",
      "description": "Tailwind CSS classes for button styling."
    },
    "buttonText": {
      "type": "string",
      "description": "Text to display on the action button."
    },
    "rsyncCommand": {
      "type": "string",
      "description": "Full rsync command for mirroring."
    },
    "isoUrl": {
      "type": "string",
      "format": "uri",
      "description": "Direct URL to ISO downloads or file browser."
    },

    "minimumRequirements": {
      "type": "string",
      "description": "Minimum system requirements."
    },
    "recommendedRequirements": {
      "type": "string",
      "description": "Recommended system requirements."
    },

    "desktopEnvironments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of supported desktop environments."
    },
    "packageManager": {
      "type": "string",
      "description": "Primary package manager (e.g., 'APT', 'eopkg', 'pacman')."
    },
    "features": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key features and highlights of the distribution."
    },

    "aboutText": {
      "type": "string",
      "description": "Additional about section text."
    },
    "historicalContext": {
      "type": "string",
      "description": "Historical background and context."
    },
    "historicalPosts": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "URLs to historical posts or articles."
    },
    "isMuseum": {
      "type": "boolean",
      "description": "Flag indicating if this is a discontinued/archived distribution."
    },
    "eos": {
      "type": "array",
      "items": { "type": "string" },
      "description": "End of support dates or information."
    },
    "communityLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Type of link (e.g., 'forum', 'chat', 'reddit')."
          },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["type", "url"]
      },
      "description": "Links to community resources."
    },

    "maintainers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "contact": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["name"]
      }
    },

    "category": {
      "type": "string",
      "enum": [
        "general",
        "security",
        "server",
        "lightweight",
        "scientific",
        "rolling",
        "indie",
        "other"
      ]
    },

    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },

    "origin": {
      "type": "object",
      "properties": {
        "country": { "type": "string" },
        "first_release": { "type": "string" },
        "parent_distro": { "type": "string" },
        "family": {
          "type": "string",
          "enum": [
            "debian",
            "ubuntu",
            "arch",
            "fedora",
            "rhel",
            "gentoo",
            "independent",
            "other"
          ]
        }
      }
    },

    "branding": {
      "type": "object",
      "properties": {
        "logo_svg": {
          "type": "string",
          "description": "Raw SVG or file path."
        },
        "color_primary": { "type": "string" },
        "color_secondary": { "type": "string" }
      }
    },

    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "caption": { "type": "string" }
        },
        "required": ["url"]
      }
    },

    "releases": {
      "type": "array",
      "description": "List of release objects, each referencing ISO and torrent metadata.",
      "items": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "codename": { "type": "string" },
          "release_date": { "type": "string" },
          "eol_date": { "type": "string" },

          "architectures": {
            "type": "array",
            "items": { "type": "string" }
          },

          "isos": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Reference to iso-image.meta.json"
            }
          },

          "torrents": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Reference to torrent.meta.json"
            }
          }
        }
      }
    },

    "mirror": {
      "type": "object",
      "description": "Link to the mirror entry in mirrors[]",
      "properties": {
        "id": { "type": "string" },
        "rsync_path": { "type": "string" },
        "http_url": { "type": "string" },
        "browse_url": { "type": "string" }
      }
    },

    "related_datasets": {
      "type": "array",
      "items": { "type": "string" }
    },

    "jsonld": {
      "type": "object",
      "description": "Auto-inserted JSON-LD block for SEO and LLM consumption."
    },

    "ai": {
      "type": "object",
      "description": "LLM-specific metadata for reasoning and auto-generation.",
      "properties": {
        "summary_prompt": { "type": "string" },
        "theme_prompt": { "type": "string" },
        "page_generation_prompt": { "type": "string" }
      }
    }
  },

  "required": ["id", "name", "description"]
}
