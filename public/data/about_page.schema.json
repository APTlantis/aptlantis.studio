{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aptlantis.net/schemas/about.schema.json",
  "title": "APTlantis About Page Schema",
  "type": "object",

  "properties": {
    "title": {
      "type": "string",
      "description": "Page title (e.g., 'About APTlantis')."
    },

    "slug": {
      "type": "string",
      "description": "URL slug for the about page (e.g., 'about')."
    },

    "summary": {
      "type": "string",
      "description": "Short description of APTlantis used for SEO and previews."
    },

    "mission": {
      "type": "string",
      "description": "Narrative describing the purpose, goals, and philosophy of APTlantis."
    },

    "content_sections": {
      "type": "array",
      "description": "Ordered narrative or informational blocks for the About page.",
      "items": {
        "type": "object",
        "properties": {
          "heading": { "type": "string" },
          "body": { "type": "string" }
        },
        "required": ["heading", "body"]
      }
    },

    "faq": {
      "type": "array",
      "description": "Frequently Asked Questions for the About page.",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional categorization tags for UI filtering."
          }
        },
        "required": ["question", "answer"]
      }
    },

    "contact": {
      "type": "object",
      "description": "Optional contact section information.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },

    "credits": {
      "type": "array",
      "description": "List of contributors, authors, or acknowledgments.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["name"]
      }
    },

    "jsonld": {
      "type": "object",
      "description": "Auto-inserted SEO/semantic metadata (pattern mirrors distro.schema.json)."
    },

    "ai": {
      "type": "object",
      "description": "LLM assistant prompts and metadata for auto-generation and updating.",
      "properties": {
        "summary_prompt": { "type": "string" },
        "faq_generation_prompt": { "type": "string" },
        "tone": { "type": "string" }
      }
    }
  },

  "required": ["title", "slug", "summary"]
}
