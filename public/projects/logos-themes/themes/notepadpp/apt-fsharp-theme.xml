        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="09072C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="242C90"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="09072C" bold="no" italic="no"  underline="no" />
