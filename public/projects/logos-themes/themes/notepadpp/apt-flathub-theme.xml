            <WordsStyle name="STRINGEOL"        fgColor="06275E"     bgColor="172637" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PROPERTYNAME"     fgColor="0969CE" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="ESCAPESEQUENCE"   fgColor="020F2B" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="KEYWORD"          fgColor="0969CE"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"         fgColor="A1D9ED"  bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

