        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="12104C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="0D0C2D"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="12104C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 3"                      fgColor=""       bgColor="312793" bold="no" italic="no" underline="no" />
