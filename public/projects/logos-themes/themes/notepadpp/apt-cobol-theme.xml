<?xml version="1.0" encoding="UTF-8" ?>
<NotepadPlus>
    <LexerStyles>

        <LexerType name="python" desc="Python" ext="py">
            <WordsStyle name="DEFAULT"      fgColor="E2EAE9"   bgColor="030617"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENTLINE"  fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"       fgColor="060E2B"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRING"       fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CHARACTER"    fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD"         fgColor="09194A"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="TRIPLE"       fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="TRIPLEDOUBLE" fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="CLASSNAME"    fgColor="09194A" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DEFNAME"      fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"     fgColor="A5C3D9"  bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="IDENTIFIER"   fgColor="E2EAE9"   bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENTBLOCK" fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="STRINGEOL"    fgColor="264BA0"     bgColor="09194A" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD2"        fgColor="060E2B" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DECORATOR"    fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="cpp" desc="C, C++" ext="cpp c h cc cxx hpp">
            <WordsStyle name="DEFAULT"      fgColor="E2EAE9"   bgColor="030617"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENT"      fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="COMMENTLINE"  fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"       fgColor="060E2B"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD"         fgColor="09194A"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="STRING"       fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CHARACTER"    fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"     fgColor="A5C3D9"  bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="IDENTIFIER"   fgColor="E2EAE9"   bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PREPROCESSOR" fgColor="060E2B" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD2"        fgColor="09194A" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD3"        fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD4"        fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="xml" desc="XML" ext="xml xsl xsd">
            <WordsStyle name="DEFAULT"          fgColor="E2EAE9"   bgColor="030617"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENT"          fgColor="192D5F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"           fgColor="060E2B"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DOUBLESTRING"     fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="SINGLESTRING"     fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="TAG"              fgColor="09194A"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="TAGEND"           fgColor="09194A"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="ATTRIBUTE"        fgColor="09194A" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CDATA"            fgColor="264BA0"     bgColor="09194A" bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="json" desc="JSON" ext="json">
            <WordsStyle name="DEFAULT"          fgColor="E2EAE9"   bgColor="030617"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="NUMBER"           fgColor="060E2B"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRING"           fgColor="264BA0"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRINGEOL"        fgColor="264BA0"     bgColor="09194A" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PROPERTYNAME"     fgColor="09194A" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="ESCAPESEQUENCE"   fgColor="060E2B" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="KEYWORD"          fgColor="09194A"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"         fgColor="A5C3D9"  bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

    </LexerStyles>

