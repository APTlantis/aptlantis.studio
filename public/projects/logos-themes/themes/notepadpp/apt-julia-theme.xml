        <WidgetStyle name="Fold margin highlight"             fgColor="ADB4BD" bgColor="212030" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="110E4C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="2C45A1"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="110E4C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 3"                      fgColor=""       bgColor="0D082A" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Mark Style 4"                      fgColor=""       bgColor="212030" bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 5"                      fgColor=""       bgColor="110E4C" bold="no" italic="no"  underline="no" />
