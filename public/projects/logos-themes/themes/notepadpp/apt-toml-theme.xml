        <WidgetStyle name="Default Style"                     fgColor="F7F6F7" bgColor="01020F"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Indent guideline style"            fgColor="262934" bgColor=""      bold="no"  italic="no"  underline="no" />
