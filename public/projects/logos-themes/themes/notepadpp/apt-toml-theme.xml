        <WidgetStyle name="Fold margin"                       fgColor="262934" bgColor="070B2D" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Fold margin highlight"             fgColor="D2D5E2" bgColor="0A144D" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="0A144D" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="2848A6"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="0A144D" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 3"                      fgColor=""       bgColor="070B2D" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Mark Style 4"                      fgColor=""       bgColor="0A144D" bold="no"  italic="no"  underline="no" />
