<?xml version="1.0" encoding="UTF-8" ?>
<NotepadPlus>
    <LexerStyles>

        <LexerType name="python" desc="Python" ext="py">
            <WordsStyle name="DEFAULT"      fgColor="E6F0EF"   bgColor="01050D"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENTLINE"  fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"       fgColor="0A334C"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRING"       fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CHARACTER"    fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD"         fgColor="031728"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="TRIPLE"       fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="TRIPLEDOUBLE" fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="CLASSNAME"    fgColor="031728" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DEFNAME"      fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"     fgColor="A1D8E0"  bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="IDENTIFIER"   fgColor="E6F0EF"   bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENTBLOCK" fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="STRINGEOL"    fgColor="186E8F"     bgColor="112836" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD2"        fgColor="0A334C" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DECORATOR"    fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="cpp" desc="C, C++" ext="cpp c h cc cxx hpp">
            <WordsStyle name="DEFAULT"      fgColor="E6F0EF"   bgColor="01050D"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENT"      fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="COMMENTLINE"  fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"       fgColor="0A334C"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD"         fgColor="031728"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="STRING"       fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CHARACTER"    fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"     fgColor="A1D8E0"  bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="IDENTIFIER"   fgColor="E6F0EF"   bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PREPROCESSOR" fgColor="0A334C" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD2"        fgColor="031728" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD3"        fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD4"        fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="xml" desc="XML" ext="xml xsl xsd">
            <WordsStyle name="DEFAULT"          fgColor="E6F0EF"   bgColor="01050D"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENT"          fgColor="1B5067"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"           fgColor="0A334C"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DOUBLESTRING"     fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="SINGLESTRING"     fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="TAG"              fgColor="031728"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="TAGEND"           fgColor="031728"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="ATTRIBUTE"        fgColor="031728" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CDATA"            fgColor="186E8F"     bgColor="112836" bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="json" desc="JSON" ext="json">
            <WordsStyle name="DEFAULT"          fgColor="E6F0EF"   bgColor="01050D"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="NUMBER"           fgColor="0A334C"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRING"           fgColor="186E8F"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRINGEOL"        fgColor="186E8F"     bgColor="112836" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PROPERTYNAME"     fgColor="031728" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="ESCAPESEQUENCE"   fgColor="0A334C" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="KEYWORD"          fgColor="031728"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"         fgColor="A1D8E0"  bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

    </LexerStyles>

