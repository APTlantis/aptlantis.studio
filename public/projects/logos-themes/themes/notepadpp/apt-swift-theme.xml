        <WidgetStyle name="Fold margin highlight"             fgColor="E3BF56" bgColor="382615" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="FDD220" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="9B2604"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="FDD220" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 3"                      fgColor=""       bgColor="D83102" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Mark Style 4"                      fgColor=""       bgColor="382615" bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 5"                      fgColor=""       bgColor="4D0A02" bold="no" italic="no"  underline="no" />
