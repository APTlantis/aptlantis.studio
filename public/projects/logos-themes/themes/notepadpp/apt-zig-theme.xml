<?xml version="1.0" encoding="UTF-8" ?>
<NotepadPlus>
    <LexerStyles>

        <LexerType name="python" desc="Python" ext="py">
            <WordsStyle name="DEFAULT"      fgColor="E0E0A2"   bgColor="06090E"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENTLINE"  fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"       fgColor="D1AB3D"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRING"       fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CHARACTER"    fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD"         fgColor="EAD365"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="TRIPLE"       fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="TRIPLEDOUBLE" fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="CLASSNAME"    fgColor="EAD365" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DEFNAME"      fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"     fgColor="C4CFAE"  bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="IDENTIFIER"   fgColor="E0E0A2"   bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENTBLOCK" fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="STRINGEOL"    fgColor="90742E"     bgColor="162A2D" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD2"        fgColor="D1AB3D" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DECORATOR"    fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="cpp" desc="C, C++" ext="cpp c h cc cxx hpp">
            <WordsStyle name="DEFAULT"      fgColor="E0E0A2"   bgColor="06090E"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENT"      fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="COMMENTLINE"  fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"       fgColor="D1AB3D"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD"         fgColor="EAD365"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="STRING"       fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CHARACTER"    fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"     fgColor="C4CFAE"  bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="IDENTIFIER"   fgColor="E0E0A2"   bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PREPROCESSOR" fgColor="D1AB3D" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD2"        fgColor="EAD365" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD3"        fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="WORD4"        fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="xml" desc="XML" ext="xml xsl xsd">
            <WordsStyle name="DEFAULT"          fgColor="E0E0A2"   bgColor="06090E"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="COMMENT"          fgColor="E0E0A2"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"           fgColor="D1AB3D"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="DOUBLESTRING"     fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="SINGLESTRING"     fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="TAG"              fgColor="EAD365"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="TAGEND"           fgColor="EAD365"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="ATTRIBUTE"        fgColor="EAD365" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="CDATA"            fgColor="90742E"     bgColor="162A2D" bold="no"  italic="no"  underline="no" />
        </LexerType>

        <LexerType name="json" desc="JSON" ext="json">
            <WordsStyle name="DEFAULT"          fgColor="E0E0A2"   bgColor="06090E"    bold="no"  italic="no"  underline="no" />
            <WordsStyle name="NUMBER"           fgColor="D1AB3D"    bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRING"           fgColor="90742E"     bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="STRINGEOL"        fgColor="90742E"     bgColor="162A2D" bold="no"  italic="no"  underline="no" />
            <WordsStyle name="PROPERTYNAME"     fgColor="EAD365" bgColor=""        bold="no"  italic="no"  underline="no" />
            <WordsStyle name="ESCAPESEQUENCE"   fgColor="D1AB3D" bgColor=""       bold="no"  italic="no"  underline="no" />
            <WordsStyle name="KEYWORD"          fgColor="EAD365"     bgColor=""        bold="yes" italic="no"  underline="no" />
            <WordsStyle name="OPERATOR"         fgColor="C4CFAE"  bgColor=""        bold="no"  italic="no"  underline="no" />
        </LexerType>

    </LexerStyles>

    <GlobalStyles>
