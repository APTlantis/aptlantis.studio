        <WidgetStyle name="Default Style"                     fgColor="F5FADA" bgColor="040A0A"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Indent guideline style"            fgColor="195D28" bgColor=""      bold="no"  italic="no"  underline="no" />
