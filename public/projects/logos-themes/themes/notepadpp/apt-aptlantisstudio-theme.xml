        <WidgetStyle name="Edge colour"                       fgColor="180F37" bgColor=""      bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Line number margin"                fgColor="666EF7" bgColor="010212" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Fold margin"                       fgColor="180F37" bgColor="010212" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Fold margin highlight"             fgColor="666EF7" bgColor="050A27" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="01E3FD" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="4D8BFD"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="01E3FD" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 3"                      fgColor=""       bgColor="01D5FC" bold="no" italic="no" underline="no" />
        <WidgetStyle name="Mark Style 4"                      fgColor=""       bgColor="050A27" bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 5"                      fgColor=""       bgColor="180F37" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Smart Highlighting"                fgColor=""       bgColor="050A27" bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="URL hovered"                       fgColor="01E3FD" bgColor=""      bold="no"  italic="no"  underline="yes" />
        <WidgetStyle name="Tags match highlighting"           fgColor=""       bgColor="262A66"   bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Tags attribute"                    fgColor="01E3FD" bgColor=""      bold="no"  italic="no"  underline="no" />
    </GlobalStyles>

</NotepadPlus>
