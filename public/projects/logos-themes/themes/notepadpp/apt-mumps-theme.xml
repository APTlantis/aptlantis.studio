        <WidgetStyle name="Fold margin highlight"             fgColor="A2DAD8" bgColor="0A2E2C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Find Mark Style"                   fgColor=""       bgColor="0A2E2C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 1"                      fgColor=""       bgColor="12413E"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 2"                      fgColor=""       bgColor="0A2E2C" bold="no" italic="no"  underline="no" />
        <WidgetStyle name="Mark Style 3"                      fgColor=""       bgColor="134E4C" bold="no" italic="no" underline="no" />
