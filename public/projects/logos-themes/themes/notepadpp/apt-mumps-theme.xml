        <WidgetStyle name="Default Style"                     fgColor="E4F1F1" bgColor="030D0D"    bold="no"  italic="no"  underline="no" />
        <WidgetStyle name="Indent guideline style"            fgColor="12413E" bgColor=""      bold="no"  italic="no"  underline="no" />
