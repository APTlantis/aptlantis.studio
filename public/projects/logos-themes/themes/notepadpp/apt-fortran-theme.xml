            <WordsStyle name="COMMENT"          fgColor="59290F"    bgColor=""        bold="no"  italic="yes" underline="no" />
            <WordsStyle name="NUMBER"           fgColor="D76C16"    bgColor=""        bold="no"  italic="no"  underline="no" />
